@using AlpineHub.Core.ViewModels.Pass
@model IEnumerable<AllPassesManageViewModel>
@{
    ViewData["Title"] = "Manage Passes";
    Layout = "_ManagerLayout";

}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <!-- Page Title -->
        <h1>@ViewBag.Title</h1>

        <!-- Add New Slope Button -->
        <a class="btn btn-success" asp-area="" asp-controller="ManagePasses" asp-action="AddPass">
            <i class="fas fa-plus"></i> Add New Pass
        </a>
    </div>

    <!-- Slopes Table -->
    <div class="table-responsive text-center">
        <table class="table table-hover">
            <thead class="">
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Description</th>
                    <th scope="col">Price</th>
                    <th scope="col">Pass Period</th>
                    <th scope="col">Pass Age group</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pass in Model)
                {
                    <tr>
                        <td hidden>@pass.Id</td>
                        <td>@pass.Name</td>
                        <td>@pass.Description</td>
                        <td>@PriceCurrency@pass.Price</td>
                        <td>@pass.Period</td>
                        <td>@pass.AgeGroup</td>

                        <td>
                            <a class="btn btn-sm btn-warning" asp-area="" asp-controller="ManagePasses" asp-action="EditPass" asp-route-id="@pass.Id">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-danger delete-pass-button">
                                <i class="fas fa-edit"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_DeleteConfirmationModalContainer" />