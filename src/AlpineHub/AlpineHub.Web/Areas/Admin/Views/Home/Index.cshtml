@using AlpineHub.Core.ViewModels.Admin
@model DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Page Title -->
        <div class="col-12 mb-4">
            <h1 class="display-5 text-center">Welcome, Admin!</h1>
            <p class="text-muted text-center">Manage users and system configurations efficiently.</p>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card border-primary shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <p class="card-text display-6 text-primary">@Model.TotalUsers</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-success shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Admins</h5>
                    <p class="card-text display-6 text-success">@Model.TotalAdmins</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-warning shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Managers</h5>
                    <p class="card-text display-6 text-warning">@Model.TotalManagers</p>
                </div>
            </div>
        </div>
    </div>


</div>