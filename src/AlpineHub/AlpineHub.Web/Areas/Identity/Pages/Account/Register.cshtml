@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Register</h2>
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="All" class="text-danger" role="alert"></div>
                <!--Email-->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" required class="form-control" aria-required="true" placeholder="example@skifun.com" />
                    <label asp-for="Input.Email">*Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <!-- First Name -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.FirstName" required class="form-control" autocomplete="firstname" aria-required="true" placeholder="John" />
                    <label asp-for="Input.FirstName">*First name</label>
                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                </div>

                <!-- Last Name -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.LastName" required class="form-control" autocomplete="lastname" aria-required="true" placeholder="Peterson" />
                    <label asp-for="Input.LastName">*Last name</label>
                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                </div>

                <!-- Birthdate -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Birthdate" type="date" required class="form-control" aria-required="true" placeholder="birthdate" />
                    <label asp-for="Input.Birthdate">*Birthdate</label>
                    <span asp-validation-for="Input.Birthdate" class="text-danger"></span>
                </div>

                <!-- Phone Number -->
                <div class=" form-floating mb-3">
                    <input asp-for="Input.PhoneNumber" type="tel" pattern="[0-9]{10}" required class="form-control" aria-required="true" placeholder="0 88 898 8989" />
                    <label asp-for="Input.PhoneNumber">*Phone number</label>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class=" form-floating mb-3">
                    <input asp-for="Input.Password" type="password" required class="form-control" aria-required="true" />
                    <label asp-for="Input.Password">*Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" type="password" required class="form-control" aria-required="true" />
                    <label asp-for="Input.ConfirmPassword">*Confirm password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <!-- Submit Button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Register</button>
                </div>
            </form>
        </div>
    </div>
</div>
