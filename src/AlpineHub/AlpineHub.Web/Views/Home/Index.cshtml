
@{
    ViewData["Title"] = "Home Page";
}


<div class="hero-section">
    <div class="hero-content">
        <h1 class="display-4">Welcome to Alpine Resort</h1>
        <p class="lead">Experience the thrill of winter sports and breathtaking mountain views.</p>
        <a href="#about" class="btn btn-primary btn-lg">Learn More</a>
    </div>
</div>

<!-- About Section -->
<section id="about" class="py-5">
    <div class="container text-center">
        <h2>About Us</h2>
        <p class="mt-3">
            Nestled in the heart of the mountains, our ski resort offers world-class slopes, cozy lodges, and unforgettable experiences for families, friends, and adventure seekers alike.
        </p>
    </div>
</section>

<!-- Featured Attractions Section -->
<section id="attractions" class="featured-section py-5 bg-light">
    <div class="container text-center">
        <h2>Our Attractions</h2>
        <div class="row mt-4">
            <div class="col-md-4">
                <img src="https://example.com/skiing.jpg" alt="Skiing" class="img-fluid">
                <h5 class="mt-3">Skiing & Snowboarding</h5>
                <p>Explore our expertly groomed slopes for all skill levels.</p>
            </div>
            <div class="col-md-4">
                <img src="https://example.com/spa.jpg" alt="Spa" class="img-fluid">
                <h5 class="mt-3">Luxury Spa</h5>
                <p>Relax and unwind with our full-service spa treatments.</p>
            </div>
            <div class="col-md-4">
                <img src="https://example.com/lodge.jpg" alt="Lodge" class="img-fluid">
                <h5 class="mt-3">Cozy Lodges</h5>
                <p>Stay in our modern yet rustic lodges with mountain views.</p>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-5">
    <div class="container text-center">
        <h2>Contact Us</h2>
        <p class="mt-3">We’d love to hear from you! Reach out for bookings or questions.</p>
        <a href="mailto:info@skiresort.com" class="btn btn-primary">Email Us</a>
    </div>
</section>