@{
    ViewData["Title"] = "Page Not Found";
}
<div class="container text-center pt-5">
    
    <h2 class="mt-3">Oops! The page you are looking for doesn’t exist.</h2>
    <p class="lead text-muted mt-4">
        The page might have been moved, renamed, or might never have existed.
    </p>
    <img src="/img/error.jpg" alt="404 Error" class="img-fluid my-4" style="max-width: 450px;">
</div>