@using AlpineHub.Core.Contracts.Pass
@using AlpineHub.Core.ViewModels.Pass
@model AllPassesSearchFilterViewModel
@inject IPassService passService
@{
    Layout = "_Layout";
    ViewData["Title"] = "Resort Passes";
    IEnumerable<string> ageGroups = await passService.GetAllAgeGroupsAsync();
    IEnumerable<string> periods = await passService.GetAllPeriodsAsync();
}

<h1 class="text-center py-3">@ViewData["Title"]</h1>
<form method="get" class="mb-4">
    <div class="row g-3 px-5">
        <!-- Age Filter -->
        <div class="form-group col-md-3">
            <div class="form-floating">
                <select asp-for="AgeFilter" class="form-select">
                    <option value="">All</option>
                    @foreach (var ageGroup in ageGroups)
                    {
                        <option value="@ageGroup">@ageGroup</option>
                    }
                </select>
                <label asp-for="AgeFilter">Age Group</label>
            </div>
        </div>

        <!-- Period Filter -->
        <div class="form-group col-md-3">
            <div class="form-floating">
                <select asp-for="PeriodFilter" class="form-select">
                    <option value="">All</option>
                    @foreach (var period in periods)
                    {
                        <option value="@period">@period</option>
                    }
                </select>
                <label asp-for="PeriodFilter">Period</label>
            </div>
        </div>

        <!-- Search Query -->
        <div class="form-group col-md-3">
            <div class="form-floating">
                <input asp-for="SearchQuery" class="form-control" placeholder="Search..." />
                <label asp-for="SearchQuery">Search</label>
            </div>
        </div>

        <!-- Submit Button -->
        <div class="col-md-3 d-flex align-items-center">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

<div class="row g-4 px-5">
    @foreach (var pass in Model.Passes!)
    {
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card shadow-sm border-primary h-100">
                <!-- Card Image -->
                <img class="card-img-top my-2" src="/img/ski-pass.png" alt="@pass.Name" style="height: 200px; object-fit: contain;" />

                <!-- Card Body -->
                <div class="card-body d-flex flex-column">
                    <!-- Pass Title -->
                    <h5 class="card-title text-primary fw-bold">@pass.Name</h5>
                    <!-- Pass Description -->
                    <p class="card-text text-muted">@pass.Description</p>

                    <!-- Pass Details -->
                    <ul class="list-group list-group-flush mb-3">
                        <li class="list-group-item">
                            <strong>Valid for:</strong> @pass.Period
                        </li>
                        <li class="list-group-item">
                            <strong>Age group:</strong> @pass.AgeGroup
                        </li>
                        <li class="list-group-item">
                            <strong>Price:</strong> @PriceCurrency@pass.Price
                        </li>
                    </ul>

                    <!-- Quantity and Add to Cart -->
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <!-- Quantity Selector -->
                        <form method="get"  class="add-to-cart-form">
                            <div class="container g-2">
                                <input type="hidden" name="passId" value="@pass.Id" />
                                <label for="quantity-@pass.Id" class="form-label"><strong>Quantity:</strong></label>
                                <input type="number"
                                       id="quantity-@pass.Id"
                                       name="quantity"
                                       class="form-control d-inline-block"
                                       style="width: 80px;"
                                       value=@pass.Quantity />
                                <button class="btn btn-primary btn-sm" type="submit">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </button>
                            </div>
                            <!-- Add to Cart Button -->
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-currentPage="@(Model.CurrentPage - 1)"
                       asp-route-searchQuery="@Model.SearchQuery"
                       asp-route-ageFilter="@Model.AgeFilter"
                       asp-route-periodFilter="@Model.PeriodFilter"
                       asp-route-passesPerPage="@Model.PassesPerPage">
                        Previous
                    </a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-currentPage="@i"
                       asp-route-searchQuery="@Model.SearchQuery"
                       asp-route-ageFilter="@Model.AgeFilter"
                       asp-route-periodFilter="@Model.PeriodFilter"
                       asp-route-passesPerPage="@Model.PassesPerPage">
                        @i
                    </a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                       asp-route-currentPage="@(Model.CurrentPage + 1)"
                       asp-route-searchQuery="@Model.SearchQuery"
                       asp-route-ageFilter="@Model.AgeFilter"
                       asp-route-periodFilter="@Model.PeriodFilter"
                       asp-route-passesPerPage="@Model.PassesPerPage">
                        Next
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>