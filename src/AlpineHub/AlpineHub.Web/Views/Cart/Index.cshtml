@using AlpineHub.Core.ViewModels.Cart
@model CartViewModel?

<div class="container pt-4">
    <h1 class="text-center">Cart</h1>

    @if (Model is not null && Model.CartItems.Any())
    {
        <table class="table table-striped text-center">
            <thead>
                <tr>
                    <th>Pass</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@PriceCurrency@item.Price</td>
                        <td style="max-width:20px;">
                            <form class="update-quantity-form">
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control" />

                            </form>
                        </td>

                        <td>$@item.TotalPrice</td>
                        <td>
                            <form asp-action="RemoveItem" asp-controller="Cart" method="post" class="d-inline">
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="text-end">
            <h4>Total: $@Model.CartTotalPrice</h4>
        </div>
        <form asp-action="ClearCart" asp-controller="Cart" method="post" class="mt-3">
            <button type="submit" class="btn btn-warning">Clear Cart</button>
        </form>
        <a class="btn btn-primary mt-3">Checkout (NotImpl)</a>
    }
    else
    {
        <h4 class="text-center">Your cart is empty.</h4>
    }
</div>