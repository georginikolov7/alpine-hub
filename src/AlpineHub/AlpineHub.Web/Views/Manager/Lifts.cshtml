@using AlpineHub.Core.ViewModels.Lift
@model IEnumerable<LiftDetailsViewModel>
@{
    ViewData["Title"] = "Manage Lifts";
    Layout = "_ManagerLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <!-- Page Title -->
        <h1>Manage Lifts</h1>

        <!-- Add New Lift Button -->
        <a class="btn btn-success" asp-area="" asp-controller="Manager" asp-action="AddLift">
            <i class="fas fa-plus"></i> Add New Lift
        </a>
    </div>

    <!-- Lifts Table -->
    <div class="table-responsive text-center">
        <table class="table table-hover" id="manageLiftsTable">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Type</th>
                    <th scope="col">Length (m)</th>
                    <th scope="col">Ascend</th>
                    <th scope="col">Ride time</th>
                    <th scope="col">Seats</th>
                    <th scope="col">Capacity</th>
                    <th scope="col">Working hours</th>
                    <th scope="col">IsOpen</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lift in Model)
                {
                    <tr>
                        <td hidden>@lift.Id</td>
                        <td>@lift.Name</td>
                        <td>@lift.Type</td>
                        <td>@lift.Length</td>
                        <td>@lift.VerticalAscend</td>
                        <td>@lift.AverageRideTime</td>
                        <td>@lift.NumberOfSeats</td>
                        <td>@lift.CapacityPerHour</td>
                        <td>@lift.OpeningHours</td>
                        <td>
                            @if (lift.IsOpen)
                            {
                                <span class="badge bg-success">Open</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Closed</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-warning" asp-area="" asp-controller="Manager" asp-action="EditLift" asp-route-id="@lift.Id">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button class="btn btn-sm btn-danger delete-lift-button">
                                <i class="fas fa-edit"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Delete Slope Confirmation Modal -->
<div class="modal fade" id="deleteLiftModal" tabindex="-1" aria-labelledby="deleteLiftModalLabel" aria-hidden="true">
    <!-- Modal will be loaded here-->
</div>