@{
    ViewData["Title"] = "Manager Dashboard";
    Layout = "_ManagerLayout";
}


<div class="container-fluid py-5">
    <div class="row">
        <!-- Page Title -->
        <div class="col-12 mb-4">
            <h1 class="display-4 text-center">Manager Dashboard</h1>
            <p class="text-center text-muted">Welcome to the Ski Resort Management Panel. Use the tools below to manage slopes, lifts, and monitor key information.</p>
        </div>
    </div>

    <div class="row">
        <!-- Card: Manage Slopes -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">Manage Slopes</h5>
                    <p class="card-text text-muted">
                        Add, edit, and view all the slopes in the resort. Keep their status and condition updated for guests.
                    </p>
                    <a asp-area="" asp-controller="ManageSlopes" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="fas fa-person-skiing"></i> Go to Slopes
                    </a>
                </div>
            </div>
        </div>

        <!-- Card: Manage Lifts -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <h5 class="card-title">Manage Lifts</h5>
                    <p class="card-text text-muted">
                        Add, edit, and monitor ski lifts. Keep information about opening hours, status, and capacity updated.
                    </p>
                    <a asp-area="" asp-controller="ManageLifts" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="fas fa-cable-car"></i> Go to Lifts
                    </a>
                </div>
            </div>
        </div>
    </div>


</div>